{
  "name": "skills-browser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "skills-browser": "./dist/skills-browser"
  },
  "scripts": {
    "dev": "NODE_ENV=development portless run --name sb bun run src/cli.ts start",
    "start": "NODE_ENV=production bun run src/cli.ts start",
    "build": "bun build --compile ./src/cli.ts --outfile ./dist/skills-browser",
    "test": "bun test",
    "lint": "oxlint src",
    "format": "oxfmt \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clack/prompts": "^0.10.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@shikijs/markdown-exit": "^4.0.2",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.132.0",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "evlog": "^2.14.0",
    "hono": "^4.10.0",
    "lucide-react": "^1.8.0",
    "markdown-exit": "^1.0.0-beta.9",
    "nuqs": "^2.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.4.0",
    "sileo": "^0.1.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "torph": "^0.0.9",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.20.0",
    "typescript": "5.9.3"
  }
}
