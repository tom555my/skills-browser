{
  "name": "skills-browser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "skills-browser": "./dist/skills-browser"
  },
  "scripts": {
    "build:css": "mkdir -p ./src/web/styles/files && cp ./node_modules/@fontsource-variable/inter/files/*.woff2 ./src/web/styles/files/ && tailwindcss -i ./src/web/styles/globals.css -o ./src/web/styles/generated.css",
    "dev": "NODE_ENV=development bun run build:css && bun --hot src/cli.ts start",
    "start": "NODE_ENV=production bun src/cli.ts start",
    "build": "bun run build:css && bun build --compile ./src/cli.ts --outfile ./dist/skills-browser",
    "test": "bun test",
    "lint": "oxlint src",
    "format": "oxfmt \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clack/prompts": "^0.10.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-router": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.10.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.20.0",
    "typescript": "5.9.3"
  }
}
