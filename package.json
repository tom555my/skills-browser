{
  "name": "skills-browser",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun --workspaces --if-present run build",
    "dev": "bun --filter=web run dev",
    "dev:all": "bun --workspaces --if-present --parallel run dev",
    "dev:cli": "bun --filter=cli run dev",
    "lint": "bun --workspaces --if-present run lint",
    "format": "bun --workspaces --if-present run format",
    "typecheck": "bun --workspaces run typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.20.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  }
}
