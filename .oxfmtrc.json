{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "es5",
  "semi": true,
  "singleQuote": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "sortTailwindcss": {
    "stylesheet": "src/web/styles/globals.css",
    "functions": ["cn", "cva"]
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    ".turbo/",
    ".output/",
    ".nitro/",
    ".tanstack/",
    ".vinxi/",
    "coverage/",
    "pnpm-lock.yaml",
    ".pnpm-store/",
    "apps/web/src/routeTree.gen.ts",
    "src/routeTree.gen.ts"
  ]
}
